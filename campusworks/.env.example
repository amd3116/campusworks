# ============================================================
# CampusWorks Environment Variables
# ============================================================
# For LOCAL development: copy this file to .env.local
# For VERCEL deployment: add these in Project Settings > Environment Variables

# REQUIRED: Generate a random secret (run: openssl rand -base64 32)
NEXTAUTH_SECRET=replace-this-with-a-random-32-char-string

# REQUIRED for Vercel: set this to your actual Vercel deployment URL
# For local dev, http://localhost:3000 is fine
NEXTAUTH_URL=https://your-app-name.vercel.app

# ============================================================
# No database is required — app uses in-memory demo data
# ============================================================
