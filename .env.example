# Copy this to .env.local for local dev
# On Vercel, add these in Project Settings > Environment Variables

# Auth Secret (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET=your_nextauth_secret_here_change_this
NEXTAUTH_URL=http://localhost:3000

# For production on Vercel, set NEXTAUTH_URL to your Vercel domain
# NEXTAUTH_URL=https://your-app.vercel.app
